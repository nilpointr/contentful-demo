# Copy to .env.local and fill in real values (see README "Environment variables").
# .env.local is gitignored — never commit real tokens.

CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=

# Settings > API keys > Add API key in the Contentful web app generates both
# of these together for a given space.
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
